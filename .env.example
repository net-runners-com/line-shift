# LINE Developers で取得した LIFF ID（ボットと同じチャネルの LIFF タブで発行したものを使う）
VITE_LIFF_ID=1234567890-AbcdEfgh

# （任意）LINE Bot のベーシックID。友だち追加リンク: https://line.me/R/ti/p/@ベーシックID
# LINE_BOT_BASIC_ID=your-basic-id

# Supabase（プロジェクト設定 > API から取得）
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# （任意）Google スプレッドシート出力用。Google Cloud Console で OAuth 2.0 クライアント ID（ウェブアプリ）を発行し、Google Sheets API を有効にしてください。
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_SECRET_ID=your-client-secret

# （任意）開発用。true にするとログインなしでテストデータを表示
# VITE_USE_MOCK_DATA=true
